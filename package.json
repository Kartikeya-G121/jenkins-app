{
  "name": "jenkins-app",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal CI/CD control plane implementation based on PRD.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev:controller": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker-node.ts",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "ioredis": "^5.10.1",
    "morgan": "^1.10.0",
    "pg": "^8.20.0",
    "uuid": "^9.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.18",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.14.2",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.2",
    "@types/yaml": "^1.9.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
